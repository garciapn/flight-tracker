# ============================================
# REQUIRED: Amadeus API Credentials
# ============================================
# Get free sandbox credentials from https://developers.amadeus.com
AMADEUS_CLIENT_ID=your_client_id_here
AMADEUS_CLIENT_SECRET=your_client_secret_here

# ============================================
# OPTIONAL: Price Alert Configuration
# ============================================
# Alert threshold (triggers when price < this value)
PRICE_THRESHOLD=1200

# ============================================
# OPTIONAL: Email Alert Configuration
# ============================================
# Enable email alerts when prices drop
# For Gmail: Generate an app-specific password
# Instructions: https://support.google.com/accounts/answer/185833

EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Alternative providers:
# Outlook: smtp.outlook.com (port 587)
# Yahoo: smtp.mail.yahoo.com (port 587)
# Custom: Check your email provider's SMTP settings

# ============================================
# Flask Configuration
# ============================================
FLASK_ENV=development
FLASK_DEBUG=False

# ============================================
# Optional: Amadeus API Environment
# ============================================
# Use 'sandbox' for testing (default), 'production' for live
AMADEUS_ENV=sandbox
