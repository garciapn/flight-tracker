# ============================================
# REQUIRED: Amadeus API Credentials
# ============================================
# Get free sandbox credentials from https://developers.amadeus.com
AMADEUS_CLIENT_ID=your_client_id_here
AMADEUS_CLIENT_SECRET=your_client_secret_here

# ============================================
# OPTIONAL: Price Alert Configuration
# ============================================
# Alert threshold (triggers when price < this value)
PRICE_THRESHOLD=1200

# ============================================
# OPTIONAL: Email Alert Configuration
# ============================================
# Enable email alerts when prices drop
# For Gmail: Generate an app-specific password
# Instructions: https://support.google.com/accounts/answer/185833

EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Alternative providers:
# Outlook: smtp.outlook.com (port 587)
# Yahoo: smtp.mail.yahoo.com (port 587)
# Custom: Check your email provider's SMTP settings

# ============================================
# OPTIONAL: SMS Alert Configuration (Twilio)
# ============================================
# Send SMS alerts for price drops
# Get free account at https://www.twilio.com

TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890  # Your Twilio phone number

# ============================================
# OPTIONAL: Slack Webhook Configuration
# ============================================
# Send alerts to Slack channel
# Create incoming webhook: https://api.slack.com/messaging/webhooks

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================
# OPTIONAL: Discord Webhook Configuration
# ============================================
# Send alerts to Discord channel
# Create webhook in Server Settings → Webhooks

DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/YOUR/WEBHOOK/URL

# ============================================
# OPTIONAL: Multi-Agent Telegram Configuration
# ============================================
# Each sub-agent can send real-time updates to Telegram
# Create a Telegram bot and channel for Flight Tracker updates

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_TRACKER_CHANNEL=@flight_tracker_updates

# Optional: Per-agent channels for detailed logging
TELEGRAM_COLLECTOR_CHANNEL=@ft_collector
TELEGRAM_ANALYZER_CHANNEL=@ft_analyzer
TELEGRAM_ALERTER_CHANNEL=@ft_alerter
TELEGRAM_MONITOR_CHANNEL=@ft_monitor
TELEGRAM_PREDICTOR_CHANNEL=@ft_predictor

# Multi-agent configuration
ENABLE_COLLECTOR_AGENT=true
ENABLE_ANALYZER_AGENT=true
ENABLE_ALERTER_AGENT=true
ENABLE_MONITOR_AGENT=true
ENABLE_PREDICTOR_AGENT=true

# ============================================
# JAMAL - Crypto Mining Master Agent
# ============================================
# Independent sub-agent for cryptocurrency mining research & operations
# Runs autonomously with Telegram updates

ENABLE_JAMAL_AGENT=true
TELEGRAM_JAMAL_CHANNEL=@jamal_crypto_mining

# Jamal's preferences (optional - he'll research everything anyway)
JAMAL_PREFERRED_COINS=BTC,ETH,XMR,KAS
JAMAL_PREFERRED_HARDWARE=GPU
JAMAL_ELECTRICITY_COST_PER_KWH=0.12
JAMAL_RISK_TOLERANCE=medium

# ============================================
# Database Configuration
# ============================================
# SQLite (development) or PostgreSQL (production)
DATABASE_ENV=sqlite  # Options: sqlite, postgresql

# PostgreSQL settings (only needed if DATABASE_ENV=postgresql)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=flight_tracker

# ============================================
# Flask Configuration
# ============================================
FLASK_ENV=development
FLASK_DEBUG=False
SECRET_KEY=your_secret_key_for_sessions

# ============================================
# Amadeus API Environment
# ============================================
# Use 'sandbox' for testing (default), 'production' for live
AMADEUS_ENV=sandbox
